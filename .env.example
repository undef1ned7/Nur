# ─────────────────────────────────────────────────────────────────
# PRODUCTION (по умолчанию, если ничего не задано)
# ─────────────────────────────────────────────────────────────────
# REST API и WebSocket идут напрямую на прод-сервер.
# VITE_API_URL не задан → api/index.js использует https://app.nurcrm.kg/api
# VITE_WS_API_URL задан ниже — WebSocket подключается к проду.
VITE_WS_API_URL=https://app.nurcrm.kg

# ─────────────────────────────────────────────────────────────────
# LOCAL DEV — разработка против локального бэкенда
# Создай .env.local (в .gitignore) и раскомментируй нужное:
# ─────────────────────────────────────────────────────────────────

# 1. IP/порт бэкенда — читается в vite.config.js, не попадает в браузер
# DEV_BACKEND=http://192.168.1.175:8000

# 2. REST: относительный путь → Vite проксирует /api → DEV_BACKEND
# VITE_API_URL=/api

# 3. WebSocket: пусто → useFunnelBoardWebSocket берёт window.location.host
#    → ws://localhost:3000/ws/... → Vite проксирует /ws → DEV_BACKEND
# VITE_WS_API_URL=

# ─────────────────────────────────────────────────────────────────
# BUILDING APP (редирект строй-сферы после логина)
# ─────────────────────────────────────────────────────────────────
# Staging: https://stroy.nurcrm.kg
# Local building SPA (по умолчанию в коде: http://localhost:3001)
# VITE_BUILDING_APP_URL=https://stroy.nurcrm.kg
# VITE_MAIN_APP_URL=https://stage.nurcrm.kg

# ─────────────────────────────────────────────────────────────────
# ПРОЧЕЕ
# ─────────────────────────────────────────────────────────────────

# Пароль регистрации (когда бэкенд-проверка отключена)
# VITE_REGISTER_ACCESS_PASSWORD=nurcrm2026

# Когда true — пароль проверяется через бэкенд, а не локально
# VITE_REGISTER_ACCESS_BACKEND=false

# Включить расширенные возможности воронки 2.0 (скоринг, лента, задачи, аналитика)
# VITE_FUNNEL_V2=true
