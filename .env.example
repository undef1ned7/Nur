# Base URL for REST API requests (Vite exposes VITE_* to the client)
# VITE_API_URL=https://app.nurcrm.kg/api

# WebSocket host for Cafe real-time updates (wss:// when the site is served over HTTPS)
# VITE_WS_API_URL=https://app.nurcrm.kg

# Local password for the registration page (used when backend check is disabled)
# VITE_REGISTER_ACCESS_PASSWORD=nurcrm2026

# When true, registration access password is validated via backend instead of local env
# VITE_REGISTER_ACCESS_BACKEND=false
